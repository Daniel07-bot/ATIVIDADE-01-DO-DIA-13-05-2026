programa {
  funcao inicio() {
    
    inteiro contador = 1
    real nota
    real soma_nota = 0.0
    real media

    enquanto(contador <=4){
    escreva("\nDigite a nota:")
    leia(nota)
    limpa()

    soma_nota = soma_nota + nota
    contador = contador + 1
    media = soma_nota / 4

    escreva("\nRESULTADO")
    escreva("\nSoma das notas:",soma_nota)
    escreva("\nMédia final:",media)
    }
    se(media >= 7.0){
      escreva("\nStatus:aprovado!")
      } senao {
        escreva("\nStatus:Reprovados")
      }
