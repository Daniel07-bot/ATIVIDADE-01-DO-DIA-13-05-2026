programa {
  funcao inicio() {
    
    inteiro contador = 1
    inteiro numero
    inteiro total_pares = 0

    escreva("contador  de Número pares\n")
    enquanto(contador <= 10){
      escreva("\nDigite o número: ")
      leia(numero)
      
      se (numero % 2 == 0)
      total_pares = total_pares + 1

      contador = contador + 1
      
      escreva("\nQuantidade de número pares digitados: ", total_pares)
      }
      
  }
}
